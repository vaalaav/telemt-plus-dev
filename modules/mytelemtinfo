#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════
#  mytelemtinfo — CLI-утилита управления telemt
#  Устанавливается автоматически в /usr/local/bin/
# ═══════════════════════════════════════════════════════════════════

CR='\e[0m' CB='\e[1m' CD='\e[2m'
CG='\e[1;32m' CY='\e[1;33m' CC='\e[1;36m' CW='\e[1;37m' CM='\e[1;35m' CRED='\e[1;31m'

_detect_config() {
    for f in /etc/telemt/telemt.toml /etc/telemt/config.toml /opt/telemt/telemt.toml; do
        [[ -f "$f" ]] && echo "$f" && return
    done
}

_print_status() {
    local cfg; cfg=$(_detect_config)

    echo ""
    echo -e "  ${CC}▐${CD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${CR}"
    echo -e "  ${CC}▐${CR}  ${CB}${CW}Telemt — статус системы${CR}"
    echo -e "  ${CC}▐${CR}"

    # telemt сервис
    if systemctl is-active --quiet telemt 2>/dev/null; then
        local ver; ver=$(/bin/telemt --version 2>/dev/null | awk '{print $2}')
        echo -e "  ${CC}▐${CR}  telemt:    ${CG}● Активен${CR} ${CD}(${ver:-?})${CR}"
    elif [[ -f /bin/telemt ]]; then
        echo -e "  ${CC}▐${CR}  telemt:    ${CRED}● Остановлен${CR}"
    else
        echo -e "  ${CC}▐${CR}  telemt:    ${CD}Не установлен${CR}"
    fi

    # Nginx
    if systemctl is-active --quiet nginx 2>/dev/null; then
        echo -e "  ${CC}▐${CR}  Nginx:     ${CG}● Активен${CR}"
    else
        echo -e "  ${CC}▐${CR}  Nginx:     ${CD}Не установлен${CR}"
    fi

    # Конфиг
    if [[ -n "$cfg" ]]; then
        echo -e "  ${CC}▐${CR}  Конфиг:    ${CW}${cfg}${CR}"

        # Домен
        local host; host=$(grep -E '^public_host' "$cfg" 2>/dev/null | head -1 | awk -F'"' '{print $2}')
        echo -e "  ${CC}▐${CR}  Домен:     ${CW}${host:-не привязан}${CR}"

        # Порт
        local port; port=$(grep -E '^port[[:space:]]*=' "$cfg" 2>/dev/null | head -1 | awk -F'=' '{print $2}' | tr -d ' ')
        echo -e "  ${CC}▐${CR}  Порт:      ${CW}${port:-?}${CR}"

        # Режим
        if grep -q '^mask *= *true' "$cfg" 2>/dev/null; then
            echo -e "  ${CC}▐${CR}  Режим:     ${CC}Selfmask${CR}"
        else
            echo -e "  ${CC}▐${CR}  Режим:     ${CG}Стандартный${CR}"
        fi

        # SYN-fix
        if grep -q 'synlimit' "$cfg" 2>/dev/null; then
            echo -e "  ${CC}▐${CR}  SYN-fix:   ${CG}● Активен${CR}"
        else
            echo -e "  ${CC}▐${CR}  SYN-fix:   ${CD}Не применён${CR}"
        fi

        # Прокси-ссылка
        local link=""
        if [[ -f /opt/telemt/proxy_links.txt ]]; then
            link=$(grep -E '^tg://' /opt/telemt/proxy_links.txt 2>/dev/null | head -1)
        fi
        if [[ -n "$link" ]]; then
            echo -e "  ${CC}▐${CR}"
            echo -e "  ${CC}▐${CR}  ${CD}── Прокси ──${CR}"
            echo -e "  ${CC}▐${CR}  ${CC}${link}${CR}"
        fi
    else
        echo -e "  ${CC}▐${CR}  Конфиг:    ${CRED}не найден${CR}"
    fi

    echo -e "  ${CC}▐${CD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${CR}"
    echo ""
}

# ── Очистка (вызов установленного cleaner или встроенная) ─────────
_run_cleaner() {
    local installer_dir="/opt/telemt-installer"
    if [[ -f "${installer_dir}/modules/utils.sh" && -f "${installer_dir}/modules/cleaner.sh" ]]; then
        source "${installer_dir}/modules/utils.sh"
        source "${installer_dir}/modules/cleaner.sh"
        cleaner_run
        return
    fi

    # Встроенный аудит
    echo ""
    echo -e "  ${CB}${CW}Аудит и очистка системы${CR}"
    echo -e "  ${CD}━━━━━━━━━━━━━━━━━━━━━━━━${CR}"

    local found=0

    # Панель
    if [[ -f /usr/local/bin/telemt-panel ]] || systemctl cat telemt-panel.service &>/dev/null 2>&1; then
        ((found++))
        echo -ne "  ${CB}Удалить панель telemt_panel? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            systemctl stop telemt-panel 2>/dev/null; systemctl disable telemt-panel 2>/dev/null
            rm -f /etc/systemd/system/telemt-panel.service /usr/local/bin/telemt-panel
            rm -rf /etc/telemt-panel /var/lib/telemt-panel
            rm -f /etc/nginx/sites-available/telemt-panel /etc/nginx/sites-enabled/telemt-panel
            id -u telemt-panel &>/dev/null && { pkill -u telemt-panel 2>/dev/null; userdel telemt-panel 2>/dev/null; } || true
            systemctl daemon-reload
            echo -e "  ${CG}✔${CR} telemt_panel удалена"
        fi
    fi

    # Selfmask
    if [[ -f /etc/nginx/sites-available/site ]] && grep -q 'selfmask\|telemt VPS Installer' /etc/nginx/sites-available/site 2>/dev/null; then
        ((found++))
        echo -ne "  ${CB}Удалить selfmask (сайт + SSL + Nginx)? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            rm -f /etc/nginx/sites-available/site /etc/nginx/sites-enabled/site
            rm -f /etc/nginx/sites-available/acme-temp /etc/nginx/sites-enabled/acme-temp
            [[ -f /etc/nginx/sites-available/default ]] && ln -sf /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default 2>/dev/null
            rm -rf /var/www/html/* 2>/dev/null; echo '<h1>nginx</h1>' > /var/www/html/index.html 2>/dev/null
            command -v certbot &>/dev/null && {
                for cn in $(certbot certificates 2>/dev/null | grep 'Certificate Name:' | awk '{print $3}'); do
                    certbot delete --cert-name "$cn" --non-interactive 2>/dev/null
                done
            }
            crontab -l 2>/dev/null | grep -v 'certbot renew' | crontab - 2>/dev/null
            nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null
            echo -e "  ${CG}✔${CR} Selfmask удалён"
        fi
    fi

    # MEKO
    if [[ -f /etc/sysctl.d/99-telemt-tuning.conf ]] || iptables -L MTPR_SYNFIX -n &>/dev/null 2>&1 || [[ -d /etc/systemd/system/telemt.service.d ]]; then
        ((found++))
        echo -ne "  ${CB}Откатить фиксы MEKO (sysctl, iptables)? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            iptables -L MTPR_SYNFIX -n &>/dev/null && {
                iptables -D INPUT -j MTPR_SYNFIX 2>/dev/null; iptables -F MTPR_SYNFIX 2>/dev/null; iptables -X MTPR_SYNFIX 2>/dev/null
            }
            local pol; pol=$(iptables -L INPUT -n 2>/dev/null | head -1 | awk -F'[()]' '{print $2}')
            [[ "$pol" == "DROP" ]] && iptables -P INPUT ACCEPT
            mkdir -p /etc/iptables; iptables-save > /etc/iptables/rules.v4 2>/dev/null
            for tbl in telemt_limit telemt_ios2_fix telemt_synlimit; do nft delete table inet "$tbl" 2>/dev/null; nft delete table ip "$tbl" 2>/dev/null; done
            rm -f /etc/sysctl.d/99-telemt-tuning.conf /etc/sysctl.d/99-custom.conf /etc/sysctl.d/99-bbr.conf
            sysctl --system &>/dev/null
            rm -rf /etc/systemd/system/telemt.service.d; systemctl daemon-reload 2>/dev/null
            echo -e "  ${CG}✔${CR} Фиксы MEKO откачены"
        fi
    fi

    # Ядро
    if [[ -f /bin/telemt ]] || systemctl cat telemt.service &>/dev/null 2>&1; then
        ((found++))
        echo -ne "  ${CRED}${CB}Удалить ядро telemt? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            systemctl stop telemt 2>/dev/null; systemctl disable telemt 2>/dev/null
            rm -f /etc/systemd/system/telemt.service /bin/telemt /usr/local/bin/mytelemtinfo
            rm -rf /etc/telemt /opt/telemt /opt/mtpr-simple /etc/systemd/system/telemt.service.d
            id -u telemt &>/dev/null && { pkill -u telemt 2>/dev/null; userdel -r telemt 2>/dev/null; } || true
            getent group telemt &>/dev/null && groupdel telemt 2>/dev/null
            systemctl daemon-reload
            echo -e "  ${CG}✔${CR} telemt удалён"
        fi
    fi

    [[ $found -eq 0 ]] && echo -e "  ${CD}Система чистая${CR}" || echo -e "\n  ${CG}✔${CR} Очистка завершена"
}

_apply_synfix() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    if grep -q 'synlimit' "$cfg" 2>/dev/null; then
        echo -e "  ${CC}●${CR} SYN-fix уже был применён ранее"
        return 0
    fi

    # Дописать блок в конец конфига
    cat >> "$cfg" << 'SYNEOF'

# SYN-fix — защита от флуда (добавлено mytelemtinfo)
[[server.listeners]]
ip = "0.0.0.0"
synlimit = "iptables"
synlimit_ios_hitcount = 15
synlimit_ios_seconds  = 1
synlimit_ios_burst    = 30
synlimit_hitcount = 54
synlimit_seconds  = 60
synlimit_burst    = 1
SYNEOF

    systemctl restart telemt 2>/dev/null
    sleep 2
    if systemctl is-active --quiet telemt 2>/dev/null; then
        echo -e "  ${CG}✔${CR} SYN-fix успешно применён и активирован"
    else
        echo -e "  ${CY}⚠${CR} SYN-fix записан, но telemt не стартовал — проверьте: journalctl -u telemt -n 20"
    fi
}

# ══════════════════════════════════════════════════════════════════
#  Главный цикл
# ══════════════════════════════════════════════════════════════════
main() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "  ${CRED}✘${CR} Запустите от root: ${CB}sudo mytelemtinfo${CR}"
        exit 1
    fi

    while true; do
        clear
        _print_status

        echo -e "  ${CB}${CW}Управление Telemt${CR}"
        echo -e "  ${CD}────────────────────────────────────${CR}"
        echo -e "    ${CB}[1]${CR} ${CB}Редактирование конфигурации${CR}"
        echo -e "    ${CB}[2]${CR} ${CB}Применить SYN-fix${CR}"
        echo -e "    ${CB}[3]${CR} ${CB}Перезапустить сервис${CR}"
        echo -e "    ${CB}[4]${CR} ${CB}Остановить сервис${CR}"
        echo -e "    ${CB}[5]${CR} ${CB}Пошаговая очистка системы${CR}"
        echo -e "    ${CB}[6]${CR} ${CB}Выход${CR}"
        echo -e "  ${CD}────────────────────────────────────${CR}"

        local choice=""
        while true; do
            echo -ne "  ${CB}Выбор${CR} [1-6]: "
            read -r choice
            case "$choice" in 1|2|3|4|5|6) break ;; *) echo -e "  ${CY}⚠${CR} Введите число от 1 до 6" ;; esac
        done

        case "$choice" in
            1)
                local cfg; cfg=$(_detect_config)
                if [[ -n "$cfg" ]]; then
                    nano "$cfg"
                    echo ""
                    echo -ne "  ${CC}●${CR} Конфиг сохранён. Перезапустить telemt? [y/N]: "
                    local yn; read -r yn
                    if [[ "$yn" =~ ^[Yy]$ ]]; then
                        systemctl restart telemt 2>/dev/null
                        sleep 2
                        systemctl is-active --quiet telemt && echo -e "  ${CG}✔${CR} telemt перезапущен" || echo -e "  ${CRED}✘${CR} Ошибка запуска"
                    fi
                else
                    echo -e "  ${CRED}✘${CR} Конфиг не найден"
                fi
                ;;
            2)
                _apply_synfix
                ;;
            3)
                systemctl restart telemt 2>/dev/null
                sleep 2
                systemctl is-active --quiet telemt && echo -e "  ${CG}✔${CR} telemt перезапущен" || echo -e "  ${CRED}✘${CR} Ошибка запуска"
                ;;
            4)
                systemctl stop telemt 2>/dev/null
                echo -e "  ${CY}⚠${CR} telemt остановлен"
                ;;
            5)
                _run_cleaner
                ;;
            6)
                echo -e "  ${CD}До свидания!${CR}"
                exit 0
                ;;
        esac

        echo ""
        echo -ne "  ${CD}Нажмите Enter...${CR}"
        read -r
    done
}

main "$@"
