        echo ""

        echo -e "  ${CB}${CW}Управление Xray${CR}"
        echo -e "  ${CD}────────────────────────────────────${CR}"
        echo -e "    ${CB}[1]${CR} ${CB}Остановить туннель${CR}"
        echo -e "    ${CB}[2]${CR} ${CB}Перезапустить туннель${CR}"
        echo -e "    ${CB}[3]${CR} ${CB}Изменить ключ подключения${CR}"
