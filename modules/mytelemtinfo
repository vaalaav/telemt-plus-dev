#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════
#  mytelemtinfo — CLI-утилита управления telemt
#  Устанавливается автоматически в /usr/local/bin/
# ═══════════════════════════════════════════════════════════════════

CR='\e[0m' CB='\e[1m' CD='\e[2m'
CG='\e[1;32m' CY='\e[1;33m' CC='\e[1;36m' CW='\e[1;37m' CM='\e[1;35m' CRED='\e[1;31m'

_detect_config() {
    for f in /etc/telemt/telemt.toml /etc/telemt/config.toml /opt/telemt/telemt.toml; do
        [[ -f "$f" ]] && echo "$f" && return
    done
}

_print_status() {
    local cfg; cfg=$(_detect_config)

    echo ""
    echo -e "  ${CC}▐${CD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${CR}"
    echo -e "  ${CC}▐${CR}  ${CB}${CW}Telemt — статус системы${CR}"
    echo -e "  ${CC}▐${CR}"

    # telemt сервис
    if systemctl is-active --quiet telemt 2>/dev/null; then
        local ver; ver=$(/bin/telemt --version 2>/dev/null | awk '{print $2}')
        echo -e "  ${CC}▐${CR}  telemt:    ${CG}● Активен${CR} ${CD}(${ver:-?})${CR}"
    elif [[ -f /bin/telemt ]]; then
        echo -e "  ${CC}▐${CR}  telemt:    ${CRED}● Остановлен${CR}"
    else
        echo -e "  ${CC}▐${CR}  telemt:    ${CD}Не установлен${CR}"
    fi

    # Nginx
    if systemctl is-active --quiet nginx 2>/dev/null; then
        echo -e "  ${CC}▐${CR}  Nginx:     ${CG}● Активен${CR}"
    else
        echo -e "  ${CC}▐${CR}  Nginx:     ${CD}Не установлен${CR}"
    fi

    # Конфиг
    if [[ -n "$cfg" ]]; then
        echo -e "  ${CC}▐${CR}  Конфиг:    ${CW}${cfg}${CR}"

        # Домен
        local host; host=$(grep -E '^public_host' "$cfg" 2>/dev/null | head -1 | awk -F'"' '{print $2}')
        echo -e "  ${CC}▐${CR}  Домен:     ${CW}${host:-не привязан}${CR}"

        # Порт
        local port; port=$(grep -E '^port[[:space:]]*=' "$cfg" 2>/dev/null | head -1 | awk -F'=' '{print $2}' | tr -d ' ')
        echo -e "  ${CC}▐${CR}  Порт:      ${CW}${port:-?}${CR}"

        # Режим
        if grep -q '^mask *= *true' "$cfg" 2>/dev/null; then
            echo -e "  ${CC}▐${CR}  Режим:     ${CC}Selfmask${CR}"
        else
            echo -e "  ${CC}▐${CR}  Режим:     ${CG}Стандартный${CR}"
        fi

        # SYN-fix
        if grep -q 'synlimit' "$cfg" 2>/dev/null; then
            echo -e "  ${CC}▐${CR}  SYN-fix:   ${CG}● Активен${CR}"
        else
            echo -e "  ${CC}▐${CR}  SYN-fix:   ${CD}Не применён${CR}"
        fi

        # MSS (client_mss / client_mss_bulk)
        local mss_val mss_bulk
        mss_val=$(grep -E '^client_mss[[:space:]]*=' "$cfg" 2>/dev/null | head -1 | awk -F'=' '{print $2}' | tr -d ' "')
        mss_bulk=$(grep -E '^client_mss_bulk[[:space:]]*=' "$cfg" 2>/dev/null | head -1 | awk -F'=' '{print $2}' | tr -d ' "')
        if [[ -n "$mss_val" && -n "$mss_bulk" ]]; then
            echo -e "  ${CC}▐${CR}  MSS:       ${CG}${mss_val}${CR} ${CD}(handshake) → ${mss_bulk} (bulk)${CR}"
        elif [[ -n "$mss_val" ]]; then
            echo -e "  ${CC}▐${CR}  MSS:       ${CG}${mss_val}${CR} ${CD}(весь трафик, без bulk-возврата)${CR}"
        else
            echo -e "  ${CC}▐${CR}  MSS:       ${CD}не задан (ядро по умолчанию)${CR}"
        fi

        # rst_on_close
        local rst_val
        rst_val=$(grep -E '^rst_on_close[[:space:]]*=' "$cfg" 2>/dev/null | head -1 | awk -F'=' '{print $2}' | tr -d ' "')
        case "$rst_val" in
            errors|always) echo -e "  ${CC}▐${CR}  RST-close: ${CG}${rst_val}${CR}" ;;
            *)             echo -e "  ${CC}▐${CR}  RST-close: ${CD}off${CR}" ;;
        esac

        # Xray туннель
        if systemctl is-active --quiet xray 2>/dev/null; then
            echo -e "  ${CC}▐${CR}  Xray:      ${CG}● Активен${CR}"
        elif [[ -f /usr/local/bin/xray ]]; then
            echo -e "  ${CC}▐${CR}  Xray:      ${CRED}● Остановлен${CR}"
        fi

        # Прокси-ссылка
        local link=""
        if [[ -f /opt/telemt/proxy_links.txt ]]; then
            link=$(grep -E '^tg://' /opt/telemt/proxy_links.txt 2>/dev/null | head -1)
        fi
        if [[ -n "$link" ]]; then
            echo -e "  ${CC}▐${CR}"
            echo -e "  ${CC}▐${CR}  ${CD}── Прокси ──${CR}"
            echo -e "  ${CC}▐${CR}  ${CC}${link}${CR}"
        fi
    else
        echo -e "  ${CC}▐${CR}  Конфиг:    ${CRED}не найден${CR}"
    fi

    echo -e "  ${CC}▐${CD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${CR}"
    echo ""
}

# ── Очистка (вызов установленного cleaner или встроенная) ─────────
_run_cleaner() {
    local installer_dir="/opt/telemt-installer"
    if [[ -f "${installer_dir}/modules/utils.sh" && -f "${installer_dir}/modules/cleaner.sh" ]]; then
        source "${installer_dir}/modules/utils.sh"
        source "${installer_dir}/modules/cleaner.sh"
        cleaner_run
        return
    fi

    # Встроенный аудит
    echo ""
    echo -e "  ${CB}${CW}Аудит и очистка системы${CR}"
    echo -e "  ${CD}━━━━━━━━━━━━━━━━━━━━━━━━${CR}"

    local found=0

    # Панель
    if [[ -f /usr/local/bin/telemt-panel ]] || systemctl cat telemt-panel.service &>/dev/null 2>&1; then
        ((found++))
        echo -ne "  ${CB}Удалить панель telemt_panel? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            systemctl stop telemt-panel 2>/dev/null; systemctl disable telemt-panel 2>/dev/null
            rm -f /etc/systemd/system/telemt-panel.service /usr/local/bin/telemt-panel
            rm -rf /etc/telemt-panel /var/lib/telemt-panel
            rm -f /etc/nginx/sites-available/telemt-panel /etc/nginx/sites-enabled/telemt-panel
            id -u telemt-panel &>/dev/null && { pkill -u telemt-panel 2>/dev/null; userdel telemt-panel 2>/dev/null; } || true
            systemctl daemon-reload
            echo -e "  ${CG}✔${CR} telemt_panel удалена"
        fi
    fi

    # Selfmask
    if [[ -f /etc/nginx/sites-available/site ]] && grep -q 'selfmask\|telemt VPS Installer' /etc/nginx/sites-available/site 2>/dev/null; then
        ((found++))
        echo -ne "  ${CB}Удалить selfmask (сайт + SSL + Nginx)? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            rm -f /etc/nginx/sites-available/site /etc/nginx/sites-enabled/site
            rm -f /etc/nginx/sites-available/acme-temp /etc/nginx/sites-enabled/acme-temp
            [[ -f /etc/nginx/sites-available/default ]] && ln -sf /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default 2>/dev/null
            rm -rf /var/www/html/* 2>/dev/null; echo '<h1>nginx</h1>' > /var/www/html/index.html 2>/dev/null
            command -v certbot &>/dev/null && {
                for cn in $(certbot certificates 2>/dev/null | grep 'Certificate Name:' | awk '{print $3}'); do
                    certbot delete --cert-name "$cn" --non-interactive 2>/dev/null
                done
            }
            crontab -l 2>/dev/null | grep -v 'certbot renew' | crontab - 2>/dev/null
            nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null
            echo -e "  ${CG}✔${CR} Selfmask удалён"
        fi
    fi

    # Nginx-служба — проверяется НЕЗАВИСИМО от наличия конфига selfmask,
    # т.к. конфиг может быть уже удалён (например selfmask-блоком выше
    # в прошлый запуск), а сама служба продолжает работать
    if systemctl is-active --quiet nginx 2>/dev/null; then
        ((found++))
        echo -ne "  ${CB}Nginx активен — [1] остановить [2] удалить [3] оставить:${CR} "
        local ng; read -r ng
        case "$ng" in
            1)
                systemctl stop nginx 2>/dev/null; systemctl disable nginx 2>/dev/null
                echo -e "  ${CG}✔${CR} Nginx остановлен и отключён"
                ;;
            2)
                systemctl stop nginx 2>/dev/null
                DEBIAN_FRONTEND=noninteractive apt-get purge -y nginx nginx-common nginx-core &>/dev/null
                rm -rf /etc/nginx
                echo -e "  ${CG}✔${CR} Nginx полностью удалён"
                ;;
            *)
                echo -e "  ${CD}Nginx оставлен${CR}"
                ;;
        esac
    fi

    # MEKO
    if [[ -f /etc/sysctl.d/99-telemt-tuning.conf ]] || iptables -L MTPR_SYNFIX -n &>/dev/null 2>&1 || [[ -d /etc/systemd/system/telemt.service.d ]]; then
        ((found++))
        echo -ne "  ${CB}Откатить фиксы MEKO (sysctl, iptables)? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            iptables -L MTPR_SYNFIX -n &>/dev/null && {
                iptables -D INPUT -j MTPR_SYNFIX 2>/dev/null; iptables -F MTPR_SYNFIX 2>/dev/null; iptables -X MTPR_SYNFIX 2>/dev/null
            }
            local pol; pol=$(iptables -L INPUT -n 2>/dev/null | head -1 | awk -F'[()]' '{print $2}')
            [[ "$pol" == "DROP" ]] && iptables -P INPUT ACCEPT
            mkdir -p /etc/iptables; iptables-save > /etc/iptables/rules.v4 2>/dev/null
            for tbl in telemt_limit telemt_ios2_fix telemt_synlimit; do nft delete table inet "$tbl" 2>/dev/null; nft delete table ip "$tbl" 2>/dev/null; done
            rm -f /etc/sysctl.d/99-telemt-tuning.conf /etc/sysctl.d/99-custom.conf /etc/sysctl.d/99-bbr.conf
            sysctl --system &>/dev/null
            rm -rf /etc/systemd/system/telemt.service.d; systemctl daemon-reload 2>/dev/null
            echo -e "  ${CG}✔${CR} Фиксы MEKO откачены"
        fi
    fi

    # Ядро
    if [[ -f /bin/telemt ]] || systemctl cat telemt.service &>/dev/null 2>&1; then
        ((found++))
        echo -ne "  ${CRED}${CB}Удалить ядро telemt? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            systemctl stop telemt 2>/dev/null; systemctl disable telemt 2>/dev/null
            rm -f /etc/systemd/system/telemt.service /bin/telemt /usr/local/bin/mytelemtinfo
            rm -rf /etc/telemt /opt/telemt /opt/mtpr-simple /etc/systemd/system/telemt.service.d
            id -u telemt &>/dev/null && { pkill -u telemt 2>/dev/null; userdel -r telemt 2>/dev/null; } || true
            getent group telemt &>/dev/null && groupdel telemt 2>/dev/null
            systemctl daemon-reload
            echo -e "  ${CG}✔${CR} telemt удалён"
        fi
    fi

    [[ $found -eq 0 ]] && echo -e "  ${CD}Система чистая${CR}" || echo -e "\n  ${CG}✔${CR} Очистка завершена"
}

_apply_synfix() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    if grep -q 'synlimit' "$cfg" 2>/dev/null; then
        echo -e "  ${CC}●${CR} SYN-fix уже был применён ранее"
        return 0
    fi

    # Бэкап перед изменением
    mkdir -p /opt/telemt/backups 2>/dev/null
    cp "$cfg" "/opt/telemt/backups/$(basename "$cfg").pre-synfix.$(date +%s)" 2>/dev/null

    # Дописать блок в конец конфига (маркеры нужны для точного отката _disable_synfix)
    cat >> "$cfg" << 'SYNEOF'

# >>> SYN-fix (mytelemtinfo) — не редактировать вручную, блок управляется автоматически
[[server.listeners]]
ip = "0.0.0.0"
synlimit = "iptables"
synlimit_ios_hitcount = 15
synlimit_ios_seconds  = 1
synlimit_ios_burst    = 30
synlimit_hitcount = 54
synlimit_seconds  = 60
synlimit_burst    = 1
# <<< SYN-fix (mytelemtinfo)
SYNEOF

    systemctl restart telemt 2>/dev/null
    sleep 2
    if systemctl is-active --quiet telemt 2>/dev/null; then
        echo -e "  ${CG}✔${CR} SYN-fix успешно применён и активирован"
    else
        echo -e "  ${CY}⚠${CR} SYN-fix записан, но telemt не стартовал — проверьте: journalctl -u telemt -n 20"
    fi
}

_disable_synfix() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    if ! grep -q 'synlimit' "$cfg" 2>/dev/null; then
        echo -e "  ${CD}SYN-fix не применён — нечего отключать${CR}"
        return 0
    fi

    mkdir -p /opt/telemt/backups 2>/dev/null
    cp "$cfg" "/opt/telemt/backups/$(basename "$cfg").pre-disable-synfix.$(date +%s)" 2>/dev/null

    if grep -q '# >>> SYN-fix (mytelemtinfo)' "$cfg" 2>/dev/null; then
        # Точное удаление блока по маркерам
        sed -i '/^# >>> SYN-fix (mytelemtinfo)/,/^# <<< SYN-fix (mytelemtinfo)/d' "$cfg"
    else
        # Старый формат без маркеров (записан предыдущей версией скрипта) — удалить по известным полям
        sed -i '/^# SYN-fix — защита от флуда/,/^synlimit_burst/d' "$cfg"
    fi

    systemctl restart telemt 2>/dev/null
    sleep 2
    if systemctl is-active --quiet telemt 2>/dev/null; then
        echo -e "  ${CG}✔${CR} SYN-fix отключён, telemt перезапущен"
    else
        echo -e "  ${CY}⚠${CR} SYN-fix удалён из конфига, но telemt не стартовал — проверьте: journalctl -u telemt -n 20"
    fi
}

# Переключатель: показывает текущее состояние и предлагает применить/отключить
_synfix_menu() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    if grep -q 'synlimit' "$cfg" 2>/dev/null; then
        echo -e "  ${CC}●${CR} SYN-fix сейчас: ${CG}применён${CR}"
        echo -ne "  ${CB}Отключить SYN-fix? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            _disable_synfix
        else
            echo -e "  ${CD}Оставлено без изменений${CR}"
        fi
    else
        echo -e "  ${CC}●${CR} SYN-fix сейчас: ${CD}не применён${CR}"
        echo -ne "  ${CB}Применить SYN-fix? [Y/n]:${CR} "
        local a; read -r a
        if [[ ! "$a" =~ ^[Nn]$ ]]; then
            _apply_synfix
        else
            echo -e "  ${CD}Отменено${CR}"
        fi
    fi
}

# ══════════════════════════════════════════════════════════════════
#  Xray Upstream Tunnel — управление
# ══════════════════════════════════════════════════════════════════
_xray_installed() {
    [[ -f /usr/local/bin/xray ]] || systemctl cat xray.service &>/dev/null 2>&1
}

# Подгрузить утилиты и логику xray_upstream.sh из установщика
# (нужна для парсинга ссылок vless/vmess/ss и генерации config.json)
_xray_load_module() {
    local installer_dir="/opt/telemt-installer"
    if [[ -f "${installer_dir}/modules/utils.sh" && -f "${installer_dir}/modules/xray_upstream.sh" ]]; then
        source "${installer_dir}/modules/utils.sh"
        source "${installer_dir}/modules/xray_upstream.sh"
        return 0
    fi
    return 1
}

_xray_stop() {
    if ! _xray_installed; then
        echo -e "  ${CD}Xray не установлен${CR}"
        return
    fi
    systemctl stop xray 2>/dev/null
    echo -e "  ${CY}⚠${CR} Xray-туннель остановлен"
}

_xray_restart() {
    if ! _xray_installed; then
        echo -e "  ${CD}Xray не установлен${CR}"
        return
    fi
    systemctl restart xray 2>/dev/null
    sleep 2
    if systemctl is-active --quiet xray 2>/dev/null; then
        echo -e "  ${CG}✔${CR} Xray-туннель перезапущен"
    else
        echo -e "  ${CRED}✘${CR} Ошибка запуска — проверьте: journalctl -u xray -n 20"
    fi
}

_xray_change_key() {
    if ! _xray_installed; then
        echo -e "  ${CD}Xray не установлен${CR}"
        return
    fi

    if ! _xray_load_module; then
        echo -e "  ${CRED}✘${CR} Модули установщика не найдены (/opt/telemt-installer)"
        echo -e "  ${CD}Переустановите ключ через полный установщик: пункт [7] Xray Upstream Tunnel${CR}"
        return 1
    fi

    echo ""
    echo -ne "  ${CB}Новый ключ подключения (vless://, vmess://, ss://):${CR} "
    local new_link
    read -r new_link

    if [[ ! "$new_link" =~ ^(vless|vmess|ss):// ]]; then
        echo -e "  ${CRED}✘${CR} Неверный формат ссылки"
        return 1
    fi

    local proto="${new_link%%://*}"
    local outbound_json=""
    case "$proto" in
        vless) outbound_json=$(_xray_parse_vless "$new_link") ;;
        vmess) outbound_json=$(_xray_parse_vmess "$new_link") ;;
        ss)    outbound_json=$(_xray_parse_ss "$new_link")    ;;
    esac

    if [[ -z "$outbound_json" ]] || ! echo "$outbound_json" | jq -e . &>/dev/null; then
        echo -e "  ${CRED}✘${CR} Ошибка парсинга ссылки"
        return 1
    fi

    mkdir -p /etc/xray/backups
    [[ -f "$XRAY_CONFIG" ]] && cp "$XRAY_CONFIG" "/etc/xray/backups/config.json.$(date +%s)" 2>/dev/null

    _xray_generate_config "$outbound_json" || {
        echo -e "  ${CRED}✘${CR} Не удалось сгенерировать конфиг"
        return 1
    }

    systemctl restart xray 2>/dev/null
    sleep 2
    if systemctl is-active --quiet xray 2>/dev/null; then
        echo -e "  ${CG}✔${CR} Ключ обновлён, Xray перезапущен"
        _xray_test_tunnel 2>/dev/null || true
        # Ключ туннеля сменился, но привязка telemt → upstreams не зависит
        # от него напрямую — на всякий случай самопроверяемся: если конфиг
        # telemt был сломан старым форматом (socks5_proxy) или привязки
        # вообще нет, восстанавливаем её здесь же, не заставляя идти
        # в полный установщик.
        _xray_verify_binding
    else
        echo -e "  ${CRED}✘${CR} Xray не запустился с новым ключом — проверьте: journalctl -u xray -n 20"
    fi
}

# Проверка/восстановление привязки telemt → Xray upstream.
# Считается корректной, только если:
#   1) есть маркированный блок [[upstreams]] от установщика
#   2) use_middle_proxy = false
#   3) нет устаревшего неподдерживаемого ключа socks5_proxy
# Если хоть одно условие не выполнено — молча пересобираем привязку
# через уже исправленную _xray_bind_telemt() (идемпотентна, с rollback).
_xray_verify_binding() {
    local cfg=""
    for f in /etc/telemt/telemt.toml /etc/telemt/config.toml; do
        [[ -f "$f" ]] && cfg="$f" && break
    done

    if [[ -z "$cfg" ]]; then
        echo -e "  ${CY}⚠${CR} Конфиг telemt не найден — привязку проверить не удалось"
        return 1
    fi

    local broken=false
    grep -q '# >>> Xray upstream (installer)' "$cfg" 2>/dev/null || broken=true
    grep -qE '^use_middle_proxy[[:space:]]*=[[:space:]]*false' "$cfg" 2>/dev/null || broken=true
    grep -qE '^socks5_proxy[[:space:]]*=' "$cfg" 2>/dev/null && broken=true

    if [[ "$broken" == "false" ]]; then
        echo -e "  ${CG}✔${CR} Привязка telemt → Xray в порядке"
        return 0
    fi

    echo -e "  ${CY}⚠${CR} Привязка telemt → Xray повреждена или отсутствует — восстанавливаю"
    if declare -F _xray_bind_telemt &>/dev/null; then
        _xray_bind_telemt
    else
        echo -e "  ${CRED}✘${CR} Функция восстановления недоступна (модуль не загружен)"
        return 1
    fi
}

# ── TOML-хелперы (аналог _toml_set в modules/optimization.sh) ─────
_toml_set_line() {
    local key="$1" value="$2" section="$3" file="$4"
    [[ -f "$file" ]] || return 1
    if grep -qE "^${key}[[:space:]]*=" "$file" 2>/dev/null; then
        sed -i "s|^${key}[[:space:]]*=.*|${key} = ${value}|" "$file"
        return 0
    fi
    if grep -qE "^\[${section}\]" "$file" 2>/dev/null; then
        sed -i "/^\[${section}\]/a ${key} = ${value}" "$file"
        return 0
    fi
    printf '\n[%s]\n%s = %s\n' "$section" "$key" "$value" >> "$file"
}

_toml_remove_line() {
    local key="$1" file="$2"
    [[ -f "$file" ]] || return 0
    sed -i "/^${key}[[:space:]]*=/d" "$file"
}

# ── MSS: client_mss + client_mss_bulk (telemt >= 3.4.19) ──────────
# client_mss фрагментирует только TLS-handshake (обход DPI по паттерну
# ClientHello), client_mss_bulk возвращает нормальный MSS на данных —
# без этого низкий MSS держится на всё соединение и множит PPS.
_apply_mss() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    mkdir -p /opt/telemt/backups 2>/dev/null
    cp "$cfg" "/opt/telemt/backups/$(basename "$cfg").pre-mss.$(date +%s)" 2>/dev/null

    _toml_set_line "client_mss" '"tspu"' "server" "$cfg"
    _toml_set_line "client_mss_bulk" '"1400"' "server" "$cfg"

    systemctl restart telemt 2>/dev/null
    sleep 2
    if systemctl is-active --quiet telemt 2>/dev/null; then
        echo -e "  ${CG}✔${CR} MSS применён: client_mss=\"tspu\" (handshake) → client_mss_bulk=\"1400\" (bulk)"
    else
        echo -e "  ${CY}⚠${CR} MSS записан, но telemt не стартовал — проверьте: journalctl -u telemt -n 20"
    fi
}

_disable_mss() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    mkdir -p /opt/telemt/backups 2>/dev/null
    cp "$cfg" "/opt/telemt/backups/$(basename "$cfg").pre-disable-mss.$(date +%s)" 2>/dev/null

    _toml_remove_line "client_mss" "$cfg"
    _toml_remove_line "client_mss_bulk" "$cfg"

    systemctl restart telemt 2>/dev/null
    sleep 2
    if systemctl is-active --quiet telemt 2>/dev/null; then
        echo -e "  ${CG}✔${CR} MSS сброшен на значение ядра, telemt перезапущен"
    else
        echo -e "  ${CY}⚠${CR} MSS убран, но telemt не стартовал — проверьте: journalctl -u telemt -n 20"
    fi
}

_mss_menu() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    local mss_val; mss_val=$(grep -E '^client_mss[[:space:]]*=' "$cfg" 2>/dev/null | head -1 | awk -F'=' '{print $2}' | tr -d ' "')

    if [[ -n "$mss_val" ]]; then
        echo -e "  ${CC}●${CR} MSS сейчас: ${CG}${mss_val}${CR} ${CD}(handshake)${CR}"
        echo -ne "  ${CB}Сбросить MSS на значение ядра? [y/N]:${CR} "
        local a; read -r a
        if [[ "$a" =~ ^[Yy]$ ]]; then
            _disable_mss
        else
            echo -e "  ${CD}Оставлено без изменений${CR}"
        fi
    else
        echo -e "  ${CC}●${CR} MSS сейчас: ${CD}не задан (ядро по умолчанию)${CR}"
        echo -ne "  ${CB}Применить client_mss=\"tspu\" + client_mss_bulk=\"1400\"? [Y/n]:${CR} "
        local a; read -r a
        if [[ ! "$a" =~ ^[Nn]$ ]]; then
            _apply_mss
        else
            echo -e "  ${CD}Отменено${CR}"
        fi
    fi
}

# ── RST-close: rst_on_close (telemt >= 3.4.x) ──────────────────────
# "errors" — мгновенный RST вместо честного FIN для соединений, не
# прошедших MTProto-хендшейк (сканеры/DPI-пробы/боты); освобождает
# orphan-сокеты быстрее. Успешные relay-сессии закрываются как обычно.
_apply_rst() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    mkdir -p /opt/telemt/backups 2>/dev/null
    cp "$cfg" "/opt/telemt/backups/$(basename "$cfg").pre-rst.$(date +%s)" 2>/dev/null

    _toml_set_line "rst_on_close" '"errors"' "general" "$cfg"

    systemctl restart telemt 2>/dev/null
    sleep 2
    if systemctl is-active --quiet telemt 2>/dev/null; then
        echo -e "  ${CG}✔${CR} rst_on_close = \"errors\" применён, telemt перезапущен"
    else
        echo -e "  ${CY}⚠${CR} rst_on_close записан, но telemt не стартовал — проверьте: journalctl -u telemt -n 20"
    fi
}

_disable_rst() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    mkdir -p /opt/telemt/backups 2>/dev/null
    cp "$cfg" "/opt/telemt/backups/$(basename "$cfg").pre-disable-rst.$(date +%s)" 2>/dev/null

    _toml_remove_line "rst_on_close" "$cfg"

    systemctl restart telemt 2>/dev/null
    sleep 2
    if systemctl is-active --quiet telemt 2>/dev/null; then
        echo -e "  ${CG}✔${CR} rst_on_close выключен (off), telemt перезапущен"
    else
        echo -e "  ${CY}⚠${CR} rst_on_close убран, но telemt не стартовал — проверьте: journalctl -u telemt -n 20"
    fi
}

_rst_menu() {
    local cfg; cfg=$(_detect_config)
    if [[ -z "$cfg" ]]; then
        echo -e "  ${CRED}✘${CR} Конфиг telemt не найден"
        return 1
    fi

    local rst_val; rst_val=$(grep -E '^rst_on_close[[:space:]]*=' "$cfg" 2>/dev/null | head -1 | awk -F'=' '{print $2}' | tr -d ' "')

    case "$rst_val" in
        errors|always)
            echo -e "  ${CC}●${CR} RST-close сейчас: ${CG}${rst_val}${CR}"
            echo -ne "  ${CB}Выключить (вернуть обычный FIN)? [y/N]:${CR} "
            local a; read -r a
            if [[ "$a" =~ ^[Yy]$ ]]; then
                _disable_rst
            else
                echo -e "  ${CD}Оставлено без изменений${CR}"
            fi
            ;;
        *)
            echo -e "  ${CC}●${CR} RST-close сейчас: ${CD}off${CR}"
            echo -ne "  ${CB}Применить rst_on_close=\"errors\"? [Y/n]:${CR} "
            local a; read -r a
            if [[ ! "$a" =~ ^[Nn]$ ]]; then
                _apply_rst
            else
                echo -e "  ${CD}Отменено${CR}"
            fi
            ;;
    esac
}

